            (mkButton "r" "пғ…" "> Recent" "Telescope oldfiles")
            (mkButton "l" "пҮҡ" "> Last session" "SessionManager load_last_session")
            (mkButton "s" "оҳ•" "> Settings" "e $HOME/flake | :cd %:p:h | split . | wincmd k | pwd")
            (mkButton "q" "пҖ‘" "> Quit NVIM" "qa")
          ];
          opts = {
            spacing = 0;
          };
        }
      ];
    };
  };
